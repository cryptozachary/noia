# ─── Server ───
PORT=3000

# ─── LLM Provider ───
# "openai" or "anthropic"
LLM_PROVIDER=openai

# ─── OpenAI ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_TEMPERATURE=0.2
OPENAI_REASONING_EFFORT=medium
OPENAI_RETRIES=2
OPENAI_TIMEOUT_MS=60000

# ─── Anthropic (optional, required if LLM_PROVIDER=anthropic) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_OUTPUT_TOKENS=4096
ANTHROPIC_RETRIES=2
ANTHROPIC_TIMEOUT_MS=90000

# ─── Web Search (optional) ───
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SEARCH_MAX_RESULTS=5

# ─── Embeddings ───
EMBEDDING_MODEL=text-embedding-3-small

# ─── Auth (optional, disabled by default) ───
REQUIRE_AUTH=false
ADMIN_API_KEY=

# ─── Agent Retry ───
AGENT_RETRIES=1
AGENT_RETRY_DELAY_MS=2000

# ─── Memory Pruning ───
MEMORY_MAX_SECTIONS=20
MEMORY_KEEP_RECENT=5
MEMORY_AUTO_PRUNE_THRESHOLD=30

# ─── Storage Backend ───
# "file" or "sqlite"
STORAGE_BACKEND=file
SQLITE_PATH=

# ─── Security ───
# Comma-separated allowed origins for CORS (default: * in dev)
CORS_ORIGIN=
# Set to "true" in production to enable strict security headers
NODE_ENV=development

# ─── Logging ───
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Directory for log files (empty = console only)
LOG_DIR=
